{
  "name": "blackmud-item-database",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "schema:api:build": "tsc --pretty false --module NodeNext --moduleResolution NodeNext --target ES2022 --outDir .tmp-openapi --rootDir src/lib/api-schema src/lib/api-schema/build-openapi.ts && node .tmp-openapi/build-openapi.js",
    "schema:api:test": "npm run schema:api:build && node scripts/test-api-schema.mjs",
    "schema:api:check": "npm run schema:api:build && git diff --exit-code -- openapi/openapi.v1.json",
    "schema:prod": "wrangler d1 execute bm_itemdb --remote --file=./d1-schema.sql",
    "schema:local": "wrangler d1 execute bm_itemdb --local --file=./d1-schema.sql",
    "lint": "eslint"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.1",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@opennextjs/cloudflare": "^1.16.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.564.0",
    "next": "15.5.10",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "typescript": "^5"
  }
}
